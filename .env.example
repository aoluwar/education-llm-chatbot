# LLM Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key
OPENAI_MODEL=gpt-4-turbo-preview
TEMPERATURE=0.7
MAX_TOKENS=2048

# Alternative LLM Providers
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_BASE_URL=http://localhost:11434

# Database
DATABASE_URL=postgresql://edubot:password@localhost:5432/education_chatbot
DATABASE_POOL_SIZE=20
DATABASE_POOL_RECYCLE=3600

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Vector Store (RAG)
VECTOR_STORE=pinecone
PINCONE_API_KEY=your-api-key
PINCONE_INDEX=education-chatbot
PINCONE_ENVIRONMENT=gcp-starter
EMBEDDING_MODEL=text-embedding-3-small

# Security
SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=your-jwt-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application
APP_NAME=Education LLM Chatbot
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# File Upload
MAX_UPLOAD_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,docx,txt,md,pptx

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@educationbot.com

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=True
ELK_ENABLED=False

# Environment
ENVIRONMENT=development
